# App
APP_NAME=Nexstage
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://nexstage.dev.localhost
NGROK_URL=

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nexstage
DB_USERNAME=nexstage
DB_PASSWORD=secret

# Redis (db 0=cache, db 1=queue, db 2=sessions)
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Mail (Mailpit in dev)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="digest@nexstage.io"
MAIL_FROM_NAME="${APP_NAME}"

# Shopify
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI="${APP_URL}/shopify/callback"
SHOPIFY_API_VERSION=2026-04
SHOPIFY_WEBHOOK_SECRET=

# Meta Ads
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/oauth/facebook/callback"

# Google (Ads + GA4 + GSC + Social Login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/oauth/google/callback"
GOOGLE_ADS_DEVELOPER_TOKEN=
PSI_API_KEY=

# Klaviyo
KLAVIYO_CLIENT_ID=
KLAVIYO_CLIENT_SECRET=
KLAVIYO_REDIRECT_URI="${APP_URL}/oauth/klaviyo/callback"

# FX Rates (Frankfurter v2 — 200+ currencies, 55 central banks)
FRANKFURTER_API_URL=https://api.frankfurter.dev/v2

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Sentry
SENTRY_LARAVEL_DSN=
